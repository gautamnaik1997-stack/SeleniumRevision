pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/gautamnaik1997-stack/SeleniumRevision.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean compile'
            }
        }

        stage('Execute Tests') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Publish Results') {
            steps {
                 junit 'target/surefire-reports/*.xml'
            }
        }
    }

    post {

        always {

        archiveArtifacts artifacts: 'reports/**'
        archiveArtifacts artifacts: 'logs/**'
        archiveArtifacts artifacts: 'Screenshots/**'

        }

    }

}
